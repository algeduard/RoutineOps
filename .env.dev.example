# Шаблон dev-окружения агента для подключения к общему dev-серверу.
# Скопируй в .env.dev и подставь свой device_id (.env.dev в .gitignore — у каждого свой сертификат).
#
# Перед запуском подними SSH-туннель к dev-серверу (порт наружу не открываем):
#   ssh -N -L 50051:localhost:50051 <user>@<dev-server> &
#
# Запуск:
#   set -a && source .env.dev && set +a && go run ./cmd/agent run

MDM_SERVER_ADDR=localhost:50051
MDM_SERVER_NAME=localhost
MDM_AGENT_CERT=certs/agents/<device-id>/agent.crt
MDM_AGENT_KEY=certs/agents/<device-id>/agent.key
MDM_CA_CERT=certs/agents/<device-id>/ca.crt

# Outbox — устойчивая очередь отчётов (security/admin/script), переживает обрывы.
# По умолчанию: каталог agent_outbox, до 1000 записей, фоновый слив раз в 30с.
# MDM_OUTBOX_DIR=agent_outbox
# MDM_OUTBOX_MAX=1000
# MDM_OUTBOX_FLUSH=30s

# Скрипт-политики (Этап 5): поллинг набора, дедуп on_connect, опрос событий ОС.
# MDM_SCRIPT_POLL=1m
# MDM_SCRIPT_DEDUP=agent_scripts.seen
# MDM_EVENT_SCAN=15s

# Самообновление (Этап 7-8): выключено, пока не задан URL manifest + публичный ключ.
# MDM_UPDATE_URL=https://<сервер>/api/v1/agent/version
# MDM_UPDATE_INTERVAL=6h
# MDM_UPDATE_PUBKEY=<base64 ed25519 публичного ключа релиза>

# Энроллмент (Этап 3, подкоманда `agent enroll`): получить mTLS-серт по токену.
#   agent enroll -enroll-url $MDM_ENROLL_URL -token $MDM_ENROLL_TOKEN \
#                -ca ca.crt -cert agent.crt -key agent.key [-install-service]
# CA из установочного пакета (-ca) пинится для проверки enroll-эндпоинта.
# MDM_ENROLL_URL=https://<сервер>:8081/api/v1/enroll
# MDM_ENROLL_TOKEN=<одноразовый токен из UI>
# MDM_ENROLL_INSTALL=1

# Источник mTLS-материала: file (по умолчанию) | keystore (macOS Keychain —
# приватный ключ не покидает хранилище, подпись делает ОС). Требует сборку
# macOS с CGO. При enroll -cert-source keystore ключ переносится в Keychain,
# а с диска удаляется; label = device_id (CN серта).
# MDM_CERT_SOURCE=keystore
# MDM_KEYSTORE_LABEL=<device_id>
