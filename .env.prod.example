# Шаблон .env.prod — скопируй в .env.prod и заполни перед деплоем.
# Не используй спецсимвол $ в паролях — он интерпретируется как переменная.

# PostgreSQL
POSTGRES_PASSWORD=сюда_пароль
DATABASE_DSN=postgres://mdm:сюда_пароль@postgres:5432/mdm?sslmode=disable

# Redis (имя сервиса в docker-compose, не localhost)
REDIS_ADDR=redis:6379

# Адреса, которые слушает сервер ВНУТРИ контейнера. Менять почти никогда не нужно:
# docker-compose.prod.yml пробрасывает 50051 наружу, а 8081 — только на 127.0.0.1.
HTTP_ADDR=:8081
GRPC_ADDR=:50051

# Каталог с опубликованными бинарями агентов (раздаётся как /downloads/*).
# Смонтирован из ./releases; менять только вместе с volume в compose.
RELEASES_DIR=./releases

# TLS сертификаты (пути внутри контейнера)
SERVER_CERT=certs/server.crt
SERVER_KEY=certs/server.key
CA_CERT=certs/ca.crt
CA_KEY=certs/ca.key

# JWT — сгенерируй: openssl rand -base64 48   (НЕ hex: сервер требует >=16 разных
# байт, а у hex алфавит ровно 16 → бывает 15 и сервер откажется стартовать)
JWT_SECRET=сюда_случайную_строку

# Ключ шифрования TOTP-секретов двухфакторной аутентификации (AES-256-GCM).
# Ровно 32 байта в base64: openssl rand -base64 32
# Живёт ТОЛЬКО в env (файл 0600, не в БД) — атакующий с одной лишь БД TOTP-секрет не
# восстановит. Если задан, но не 32 байта → сервер откажется стартовать.
# Оставить пустым можно: MFA просто нельзя будет включить (enroll вернёт 503), а у уже
# включивших TOTP-вход деградирует до recovery-кода (в лог пойдёт warn). ПОТЕРЯ ключа не
# блокирует вход (работают recovery-коды и admin-reset MFA), но требует переустановки MFA.
# Требуется синхронизированное время сервера (NTP): дрейф >30с ломает проверку TOTP.
ROUTINEOPS_MFA_ENC_KEY=

# Первый admin (создаётся один раз при первом запуске).
# Пароль обязан пройти политику сложности: >=8 символов и минимум 3 из 4 классов
# (строчные/прописные/цифры/спецсимволы). Слабый пароль => админ НЕ создастся,
# в логе сервера будет `seed admin failed`.
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=сюда_пароль

# Публичный URL сервера (используется в installer-скриптах для агентов)
# Используй http:// если HTTPS не настроен
PUBLIC_WEB_URL=https://mdm.example.com

# Secure-флаг на cookie админ-сессии. true — cookie уходит ТОЛЬКО по HTTPS.
# Штатный деплой (nginx на 443) обязан ставить true; false оставляют лишь для
# локальной отладки по http://localhost. Любое значение кроме `true` = выключено.
COOKIE_SECURE=true

# Публичный ключ подписи релизов агента (self-update). НЕ заполнять вручную —
# install.sh генерирует per-deployer keypair (release_ed25519.pem, приватник 0600
# НЕ покидает машину) и дописывает сюда base64(raw ed25519 pubkey). Сервер отдаёт
# его агенту в ответе на enroll; универсальные установщики (MSI/.pkg) ключ не
# вшивают. См. docs/self-hosted-deploy.md.
RELEASE_PUBKEY=

# Retention (дни). DATA_RETENTION_DAYS — операционные данные (alerts, script_results).
# AUDIT_RETENTION_DAYS — ОТДЕЛЬНЫЙ длинный срок для audit_log (журнал безопасности не
# должен стираться коротким операционным сроком). 0 = хранить бессрочно.
DATA_RETENTION_DAYS=7
AUDIT_RETENTION_DAYS=365

# Минут без heartbeat до alert agent_unreachable (детектор-тикер каждые 5 мин).
# 10080 = 7 суток: алерт про реально выпавшую из парка машину, а не про выходные,
# отпуск с ноутбуком или отключённый VPN.
AGENT_UNREACHABLE_MINUTES=10080
# Окно подавления повторных agent_unreachable по одному устройству (минут). Гасит
# дребезг modern-standby (машина просыпается ~раз в час → каждый сон = новый эпизод).
# 0 = без cooldown (только эпизодный анти-дубль). По умолчанию 360 (6ч).
AGENT_UNREACHABLE_COOLDOWN_MINUTES=360

# SMTP для email-уведомлений (пустой SMTP_HOST = почта отключена, в логе `mailer disabled`)
# Порт 587 = STARTTLS (SMTP_TLS=false); порт 465 = implicit TLS (SMTP_TLS=true).
# Многие провайдеры требуют app-password (не пароль от ящика) и From == SMTP_USER.
# SMTP_FROM по умолчанию (если не задан) — noreply@mdm.local; такой домен отвергнет
# любой реальный релей, поэтому при включённой почте задавай его явно.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@mdm.local
SMTP_TLS=false

# Telegram-бот для алертов (оставь пустым чтобы отключить).
# Бот СВОЙ у каждой инсталляции: создайте его у @BotFather (/newbot) и вставьте токен.
# Имя бота сервер узнаёт сам (getMe) и показывает в панели — вшивать его никуда не надо.
TELEGRAM_BOT_TOKEN=

# FileVault recovery-escrow — ENTERPRISE-фича (carve-out). Open-core (free) образ,
# который собирает этот compose, её НЕ содержит: escrow RPC → Unimplemented,
# lock mode=filevault → 409, ESCROW_* ниже free-сервером ИГНОРИРУЮТСЯ (оверлей-лок
# работает как раньше). Включение возможно ТОЛЬКО на enterprise-сборке
# (go build -tags enterprise; см. enterprise-документацию)
# и только после гейта G1-G3:
#   1) офлайн: сгенерировать recipient-ключ; приватный ключ на сервер НЕ попадает;
#   2) ESCROW_RECIPIENT=age1... (публичный recipient; runtime-env);
#   3) ESCROW_RECIPIENT_FPR= результат `routineops-server -escrow-fpr age1...` — ldflags-пин
#      в enterprise-бинарь на сборке;
#   4) проверка: GET /api/v1/escrow/status (за JWT, enterprise) => {"enabled":true,...}.
#      Сервер с recipient, но без пина / с чужим пином НЕ СТАРТУЕТ (анти-подмена).
ESCROW_RECIPIENT=
ESCROW_RECIPIENT_FPR=
