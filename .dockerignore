# build-контекст сервера = корень (Dockerfile: COPY . . в builder-стадии). Секреты
# СЮДА попадать НЕ должны — иначе приватник подписи релизов и .env.prod (JWT_SECRET,
# пароль БД) осядут в builder-слое/кэше даже если runtime-образ их не содержит.
# Образу для сборки нужны ТОЛЬКО Go-исходники + migrations/ (COPY migrations/ в runtime).

# Секреты
release_ed25519.pem*
.env
.env.*
*.env
*.pem
*.key
certs/
backups/

# Артефакты релизов/сборки (образу не нужны, раздувают контекст)
releases/
bin/
*.msi
*.pkg
*.exe

# Не-серверное
web/
.git/
node_modules/
