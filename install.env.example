# ─────────────────────────────────────────────────────────────────────────────
# Параметры установки RoutineOps-сервера. БЫСТРЫЙ СТАРТ:
#   cp install.env.example install.env
#   nano install.env            # заполни PUBLIC_ADDR и ADMIN_*
#   ./install.sh                # без sudo, от пользователя в группе docker
#
# install.env лежит в .gitignore (в нём пароль администратора) — НЕ коммить его.
# Инлайновые переменные при запуске (VAR=... ./install.sh) переопределяют этот файл.
# ─────────────────────────────────────────────────────────────────────────────

# ============================ ОБЯЗАТЕЛЬНО ====================================

# Внешний адрес сервера — по нему к нему обращаются АГЕНТЫ и БРАУЗЕРЫ (IP или домен).
# За NAT/VPN это НЕ то, что отдаёт `hostname -I` (там внутренний IP): укажи внешний
# адрес ЯВНО, иначе enroll по внешнему адресу упадёт на TLS — он обязан быть в SAN
# сертификата. Внутренний IP хоста добавляется в SAN автоматически, его писать не надо.
#   PUBLIC_ADDR=203.0.113.10      # внешний IP
#   PUBLIC_ADDR=mdm.example.com   # домен
PUBLIC_ADDR=

# Первый администратор (создаётся при первом старте). Пароль обязан пройти политику
# сложности: 8+ символов, минимум 3 из 4 классов (строчные/ПРОПИСНЫЕ/цифры/спецсимволы),
# иначе админ молча не создастся и войти будет некем.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=

# ============================ ОПЦИОНАЛЬНО ====================================

# Доп. DNS-имя в SAN сертификата (если к серверу ходят и по IP, и по доменному имени,
# а PUBLIC_ADDR — это IP).
#SERVER_HOST=mdm.example.com

# SMTP для инвайтов и сброса пароля. Пустой SMTP_HOST = почта выключена.
# Порт↔TLS ДОЛЖНЫ совпадать: 587 = STARTTLS → SMTP_TLS=false; 465 = implicit TLS → SMTP_TLS=true.
#SMTP_HOST=
#SMTP_PORT=587
#SMTP_USER=
#SMTP_PASS=
#SMTP_FROM=noreply@example.com
#SMTP_TLS=false

# Telegram-бот для алертов безопасности. Пусто = выключен.
#TELEGRAM_BOT_TOKEN=

# Secure-флаг на cookie сессий — ставь true, если фронт всегда за HTTPS.
#COOKIE_SECURE=true

# Хранение данных телеметрии и аудита (в днях).
#DATA_RETENTION_DAYS=7
#AUDIT_RETENTION_DAYS=365
